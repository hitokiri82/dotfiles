FPATH="$(brew --prefix)/share/zsh/site-functions:${FPATH}"
export LESS=-FR
DEFAULT_USER="fcaraballo"

# Load module terminfo, provided by zsh. It should happen auto, but it doesnt hurt
zmodload zsh/terminfo

export ZSH="$HOME/.oh-my-zsh"

ZSH_THEME="agnoster"

plugins=(ssh git command-not-found history-substring-search)

source $ZSH/oh-my-zsh.sh

export VOLTA_HOME="$HOME/.volta"
export PATH="$VOLTA_HOME/bin:$PATH"

alias ls='ls -alh'

alias gitg='gitg -b'

#libpq adds postgres utilities (pg_dump, psql, etc) without installing the full database
export PATH="/opt/homebrew/opt/libpq/bin:$PATH"

complete -C aws_completer aws

test -e "${HOME}/.iterm2_shell_integration.zsh" && source "${HOME}/.iterm2_shell_integration.zsh"

eval "$(uv generate-shell-completion zsh)"
eval "$(uvx --generate-shell-completion zsh)"

eval "$(direnv hook zsh)"

function read_env {
  export $(xargs <$1)
}
eval "$(ty generate-shell-completion zsh)"
